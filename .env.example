# Copia este archivo a .env.local y completa los valores.
# En Vercel: configurar como Environment Variables (nunca subir .env.local).

# Neon Postgres — cadena con pooler, empieza con postgresql:// y termina en ?sslmode=require
DATABASE_URL=

# Secreto de firma de la cookie de sesión (obligatorio en producción).
# Generar con: openssl rand -base64 48
SESSION_SECRET=

# Web Push (VAPID). Generar par con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Misma clave pública, expuesta al navegador
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Solo para el seed: contraseña inicial del usuario admin (obligatoria, sin default)
ADMIN_PASSWORD=

# --- Fases futuras ---
# Vercel Blob (fotos en anotaciones)
# BLOB_READ_WRITE_TOKEN=
# Protección del cron de recordatorios
# CRON_SECRET=
